{
	"name": "template-early-hints-salesforce-scraper",
	"version": "1.0.0",
	"description": "Early hints template, with a Salesforce ecommerce backend web scraper designed to pull LCP image links for PDP pages and update static asset version hashes every hour.",
	"type": "module",
	"scripts": {
		"generate:types": "graphql-codegen --config codegen.ts",
		"build": "tsc",
		"dev": "tsc; harperdb dev .",
		"format": "prettier --write .",
		"postinstall": "npm link harperdb",
		"postuninstall": "npm link harperdb"
	},
	"prettier": "@harperdb/code-guidelines/prettier",
	"author": "HarperDB, Inc.",
	"devDependencies": {
		"@graphql-codegen/cli": "^5.0.3",
		"@graphql-codegen/typescript": "^4.1.2",
		"@graphql-codegen/typescript-operations": "^4.4.0",
		"@harperdb/code-guidelines": "^0.0.2",
		"@types/node": "^22.10.2",
		"graphql": "^16.10.0",
		"prettier": "^3.4.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"dependencies": {
		"fast-xml-parser": "^5.2.5"
	}
}
